# ============================================================
# LFS — Lusaka Fitness Squad | Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Public-facing URL (used in OG meta tags)
SITE_URL=https://www.lfszambia.run

# ── Email (Nodemailer — uncomment when ready) ────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# CONTACT_EMAIL=info@lfszambia.run

# ── Database (MongoDB — uncomment when ready) ────────────────
# MONGODB_URI=mongodb://localhost:27017/lfs

# ── Session (if you add auth later) ─────────────────────────
# SESSION_SECRET=change_this_to_a_long_random_string
