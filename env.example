# Copy to `.env` in the project root (same folder as index.php).
# If a legacy `public/.env` exists, index.php will load it when root `.env` is missing.
# `.env` is gitignored — use different values on each server without merge conflicts.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=lfs_db
DB_USER=root
DB_PASS=

# Optional (default utf8mb4 if omitted)
# DB_CHARSET=utf8mb4
