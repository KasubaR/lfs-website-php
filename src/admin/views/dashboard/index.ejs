<%
  /* ─────────────────────────────────────────────────────────
     dashboard/index.ejs — LFS Admin Dashboard
     Requires adminAuth.middleware.js + role.middleware('admin')
     Variables expected from controller:
       - adminUser       { name, email, role }
       - stats           { totalMembers, activeMembers, upcomingEvents,
                           pendingOrders, monthlyRevenue, galleryUploads }
       - recentActivity  []
       - pendingTasks    { orders, events, gallery, memberships }
       - notifications   { unread, items }
       - counts          { pendingMembers, pendingOrders, pendingGallery }
       - chartData       { members[], events[], sales[], gallery[] }
     ──────────────────────────────────────────────────────── */

  pageTitle   = 'Dashboard';
  activePage  = 'dashboard';
  breadcrumbs = [];
%>

<!-- ══════════════════════════════════════════════
     1. STATS CARDS
════════════════════════════════════════════════ -->
<section class="stats-grid" aria-label="Key metrics">

  <!-- Total Members -->
  <article class="stat-card stat-card--green" aria-label="Total members">
    <div class="stat-card__icon" aria-hidden="true">
      <i class="fas fa-users"></i>
    </div>
    <p class="stat-card__label">Total Members</p>
    <p class="stat-card__value" id="stat-total-members">
      <%= typeof stats !== 'undefined' ? stats.totalMembers.toLocaleString() : '—' %>
    </p>
    <div class="stat-card__meta">
      <span class="stat-card__trend stat-card__trend--up" aria-label="Up 12% this month">
        <i class="fas fa-arrow-up" aria-hidden="true"></i> 12%
      </span>
      <span>vs last month</span>
    </div>
  </article>

  <!-- Active Members -->
  <article class="stat-card stat-card--green" aria-label="Active members this month">
    <div class="stat-card__icon" aria-hidden="true">
      <i class="fas fa-user-check"></i>
    </div>
    <p class="stat-card__label">Active Members</p>
    <p class="stat-card__value" id="stat-active-members">
      <%= typeof stats !== 'undefined' ? stats.activeMembers.toLocaleString() : '—' %>
    </p>
    <div class="stat-card__meta">
      <span style="font-size:0.68rem; color:var(--text-dim);">This month</span>
    </div>
  </article>

  <!-- Upcoming Events -->
  <article class="stat-card stat-card--red" aria-label="Upcoming events in next 30 days">
    <div class="stat-card__icon" aria-hidden="true">
      <i class="fas fa-calendar-days"></i>
    </div>
    <p class="stat-card__label">Upcoming Events</p>
    <p class="stat-card__value" id="stat-upcoming-events">
      <%= typeof stats !== 'undefined' ? stats.upcomingEvents : '—' %>
    </p>
    <div class="stat-card__meta">
      <span style="font-size:0.68rem; color:var(--text-dim);">Next 30 days</span>
    </div>
  </article>

  <!-- Pending Orders -->
  <article class="stat-card stat-card--orange" aria-label="Pending shop orders">
    <div class="stat-card__icon" aria-hidden="true">
      <i class="fas fa-bag-shopping"></i>
    </div>
    <p class="stat-card__label">Pending Orders</p>
    <p class="stat-card__value" id="stat-pending-orders">
      <%= typeof stats !== 'undefined' ? stats.pendingOrders : '—' %>
    </p>
    <div class="stat-card__meta">
      <% if (typeof stats !== 'undefined' && stats.pendingOrders > 0) { %>
        <span class="stat-card__trend stat-card__trend--down" aria-label="Needs attention">
          <i class="fas fa-circle-exclamation" aria-hidden="true"></i> Action needed
        </span>
      <% } else { %>
        <span style="font-size:0.68rem;color:var(--text-dim);">All clear</span>
      <% } %>
    </div>
  </article>

  <!-- Monthly Revenue -->
  <article class="stat-card stat-card--gold" aria-label="Monthly revenue">
    <div class="stat-card__icon" aria-hidden="true">
      <i class="fas fa-circle-dollar-to-slot"></i>
    </div>
    <p class="stat-card__label">Revenue</p>
    <p class="stat-card__value" id="stat-revenue" style="font-size:1.6rem; letter-spacing:0.01em;">
      K <%= typeof stats !== 'undefined' ? stats.monthlyRevenue.toLocaleString() : '—' %>
    </p>
    <div class="stat-card__meta">
      <span style="font-size:0.68rem;color:var(--text-dim);">This month</span>
    </div>
  </article>

  <!-- Gallery Uploads -->
  <article class="stat-card stat-card--green" aria-label="Gallery uploads this month">
    <div class="stat-card__icon" aria-hidden="true">
      <i class="fas fa-images"></i>
    </div>
    <p class="stat-card__label">Gallery Uploads</p>
    <p class="stat-card__value" id="stat-gallery">
      <%= typeof stats !== 'undefined' ? stats.galleryUploads : '—' %>
    </p>
    <div class="stat-card__meta">
      <span style="font-size:0.68rem;color:var(--text-dim);">This month</span>
    </div>
  </article>

</section>


<!-- ══════════════════════════════════════════════
     2. QUICK ACTIONS
════════════════════════════════════════════════ -->
<section class="quick-actions" aria-label="Quick actions">
  <a href="/admin/events/create"   class="btn-quick btn-quick--green">
    <i class="fas fa-plus" aria-hidden="true"></i> Add Event
  </a>
  <a href="/admin/products/create" class="btn-quick btn-quick--outline">
    <i class="fas fa-plus" aria-hidden="true"></i> Add Product
  </a>
  <a href="/admin/blog/new"     class="btn-quick btn-quick--outline">
    <i class="fas fa-plus" aria-hidden="true"></i> Add Blog
  </a>
  <a href="/admin/gallery/upload" class="btn-quick btn-quick--outline">
    <i class="fas fa-upload" aria-hidden="true"></i> Upload Gallery
  </a>
</section>


<!-- ══════════════════════════════════════════════
     3. UPCOMING EVENTS
════════════════════════════════════════════════ -->
<section class="admin-panel" aria-label="Upcoming events">
  <div class="admin-panel__header">
    <h2 class="admin-panel__title">
      <span class="admin-panel__title-dot" style="background:var(--flag-red);" aria-hidden="true"></span>
      Upcoming Events
    </h2>
    <a href="/admin/events/list" class="admin-panel__action">View all →</a>
  </div>
  <div class="admin-panel__body">
    <% if (Array.isArray(upcomingEvents) && upcomingEvents.length) { %>
      <ul class="upcoming-events" aria-label="Next scheduled events">
        <% upcomingEvents.forEach(function(ev) { %>
          <li class="upcoming-events__item">
            <div class="upcoming-events__main">
              <span class="upcoming-events__title"><%= ev.title %></span>
              <span class="upcoming-events__meta">
                <i class="fas fa-calendar-day" aria-hidden="true"></i>
                <%= ev.eventDate ? new Date(ev.eventDate).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : 'TBA' %>
                <% if (ev.location) { %>
                  &nbsp;·&nbsp;
                  <i class="fas fa-location-dot" aria-hidden="true"></i>
                  <%= ev.location %>
                <% } %>
              </span>
            </div>
            <div class="upcoming-events__actions">
              <a href="/events/<%= ev.slug || ev.id %>" class="admin-btn admin-btn--ghost admin-btn--sm" target="_blank" rel="noopener">
                View
              </a>
              <a href="/admin/events/<%= ev.id %>/edit" class="admin-btn admin-btn--primary admin-btn--sm">
                Edit
              </a>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="upcoming-events__empty">
        No upcoming events scheduled in Supabase. Create a new event to see it here.
      </p>
    <% } %>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     4. CHARTS ROW
════════════════════════════════════════════════ -->
<section class="charts-grid" aria-label="Analytics charts">

  <!-- Main chart: Member Registrations + Event Attendance -->
  <div class="admin-panel" aria-label="Monthly registrations and attendance">
    <div class="admin-panel__header">
      <h2 class="admin-panel__title">
        <span class="admin-panel__title-dot" style="background:var(--flag-green);" aria-hidden="true"></span>
        Registrations &amp; Attendance
      </h2>
      <div style="display:flex;gap:0.5rem;align-items:center;">
        <select id="chartPeriodSelect"
                class="admin-input"
                style="width:auto;padding:0.3rem 0.6rem;font-size:0.75rem;"
                aria-label="Select chart period"
                onchange="updateMainChart(this.value)">
          <option value="6">Last 6 months</option>
          <option value="12" selected>Last 12 months</option>
          <option value="24">Last 24 months</option>
        </select>
      </div>
    </div>
    <div class="admin-panel__body">
      <div class="chart-wrapper" style="height:260px; position:relative;">
        <div class="loading-overlay" id="chartMainLoader" aria-label="Loading chart">
          <div class="loading-spinner"></div>
        </div>
        <canvas id="chartMain" aria-label="Member registrations and event attendance chart"></canvas>
      </div>
    </div>
  </div>

  <!-- Secondary chart: Sales performance -->
  <div class="admin-panel" aria-label="Sales performance">
    <div class="admin-panel__header">
      <h2 class="admin-panel__title">
        <span class="admin-panel__title-dot" style="background:var(--flag-orange);" aria-hidden="true"></span>
        Sales Performance
      </h2>
    </div>
    <div class="admin-panel__body">
      <div class="chart-wrapper" style="height:260px;position:relative;">
        <div class="loading-overlay" id="chartSalesLoader" aria-label="Loading chart">
          <div class="loading-spinner"></div>
        </div>
        <canvas id="chartSales" aria-label="Sales performance chart"></canvas>
      </div>
    </div>
  </div>

</section>


<!-- ══════════════════════════════════════════════
     4. RECENT ACTIVITY + PENDING TASKS
════════════════════════════════════════════════ -->
<section class="content-grid" aria-label="Activity and tasks">

  <!-- Recent Activity Feed -->
  <div class="admin-panel" aria-label="Recent activity">
    <div class="admin-panel__header">
      <h2 class="admin-panel__title">
        <span class="admin-panel__title-dot" style="background:var(--flag-green);" aria-hidden="true"></span>
        Recent Activity
      </h2>
      <a href="/admin/activity" class="admin-panel__action" aria-label="View all activity">View all →</a>
    </div>
    <div class="admin-panel__body" style="padding:0 1.25rem;" id="activityFeed">

      <% if (typeof recentActivity !== 'undefined' && recentActivity.length) { %>
        <% recentActivity.slice(0, 8).forEach(function(item) { %>
          <div class="activity-item">
            <div class="activity-icon activity-icon--<%= item.type %>" aria-hidden="true">
              <i class="<%= item.icon %>"></i>
            </div>
            <div class="activity-content">
              <p class="activity-title"><%= item.title %></p>
              <p class="activity-sub"><%= item.subtitle %></p>
            </div>
            <time class="activity-time" datetime="<%= item.isoDate %>"><%= item.timeAgo %></time>
          </div>
        <% }); %>
      <% } else { %>
        <!-- Skeleton placeholders while JS loads -->
        <% for (let i = 0; i < 5; i++) { %>
          <div class="activity-item" aria-hidden="true">
            <div class="skeleton" style="width:32px;height:32px;border-radius:8px;flex-shrink:0;"></div>
            <div class="activity-content">
              <div class="skeleton" style="height:12px;width:60%;margin-bottom:6px;"></div>
              <div class="skeleton" style="height:10px;width:40%;"></div>
            </div>
            <div class="skeleton" style="height:10px;width:40px;"></div>
          </div>
        <% } %>
      <% } %>

    </div>
  </div>


  <!-- Pending Tasks -->
  <div class="admin-panel" aria-label="Pending tasks">
    <div class="admin-panel__header">
      <h2 class="admin-panel__title">
        <span class="admin-panel__title-dot" style="background:var(--flag-orange);" aria-hidden="true"></span>
        Pending Tasks
      </h2>
      <span style="font-size:0.7rem;color:var(--text-dim);">Needs attention</span>
    </div>
    <div class="admin-panel__body" style="padding:0 1.25rem;">

      <% const tasks = typeof pendingTasks !== 'undefined' ? pendingTasks : {}; %>

      <!-- Orders -->
      <div class="task-item">
        <div class="task-priority task-priority--high" aria-hidden="true"></div>
        <span class="task-label">
          <i class="fas fa-bag-shopping" style="margin-right:0.4rem;opacity:0.5;" aria-hidden="true"></i>
          Orders to process
        </span>
        <span class="task-count" aria-label="<%= tasks.orders || 0 %> orders"><%= tasks.orders || 0 %></span>
        <a href="/admin/orders?status=pending" class="task-action" aria-label="Process pending orders">Process →</a>
      </div>

      <!-- Events -->
      <div class="task-item">
        <div class="task-priority task-priority--medium" aria-hidden="true"></div>
        <span class="task-label">
          <i class="fas fa-calendar-days" style="margin-right:0.4rem;opacity:0.5;" aria-hidden="true"></i>
          Events to publish
        </span>
        <span class="task-count" aria-label="<%= tasks.events || 0 %> events"><%= tasks.events || 0 %></span>
        <a href="/admin/events?status=draft" class="task-action" aria-label="Review draft events">Review →</a>
      </div>

      <!-- Gallery -->
      <div class="task-item">
        <div class="task-priority task-priority--low" aria-hidden="true"></div>
        <span class="task-label">
          <i class="fas fa-images" style="margin-right:0.4rem;opacity:0.5;" aria-hidden="true"></i>
          Gallery awaiting approval
        </span>
        <span class="task-count" aria-label="<%= tasks.gallery || 0 %> items"><%= tasks.gallery || 0 %></span>
        <a href="/admin/gallery?status=pending" class="task-action" aria-label="Approve gallery uploads">Approve →</a>
      </div>

      <!-- Memberships -->
      <div class="task-item">
        <div class="task-priority task-priority--medium" aria-hidden="true"></div>
        <span class="task-label">
          <i class="fas fa-user-clock" style="margin-right:0.4rem;opacity:0.5;" aria-hidden="true"></i>
          New membership approvals
        </span>
        <span class="task-count" aria-label="<%= tasks.memberships || 0 %> members"><%= tasks.memberships || 0 %></span>
        <a href="/admin/members?status=pending" class="task-action" aria-label="Approve new memberships">Approve →</a>
      </div>

    </div><!-- /.admin-panel__body -->

    <!-- System Notifications -->
    <div class="admin-panel__header" style="margin-top:0.5rem;">
      <h2 class="admin-panel__title">
        <span class="admin-panel__title-dot" style="background:var(--flag-red);" aria-hidden="true"></span>
        System Alerts
      </h2>
    </div>
    <div style="padding:0.75rem 1.25rem 1.25rem;" id="sysAlerts">

      <% if (typeof systemAlerts !== 'undefined' && systemAlerts.length) { %>
        <% systemAlerts.forEach(function(alert) { %>
          <div class="sys-notif sys-notif--<%= alert.type %>" role="alert">
            <i class="<%= alert.icon %>" aria-hidden="true"></i>
            <span><%= alert.message %></span>
          </div>
        <% }); %>
      <% } else { %>
        <div class="sys-notif sys-notif--info" role="status">
          <i class="fas fa-check-circle" aria-hidden="true"></i>
          <span>All systems operational</span>
        </div>
      <% } %>

    </div>
  </div>

</section>


<!-- ══════════════════════════════════════════════
     5. CHART DATA — injected from server
════════════════════════════════════════════════ -->
<script id="dashboardData" type="application/json">
  <%- JSON.stringify({
    chartData: typeof chartData !== 'undefined' ? chartData : null,
    stats:     typeof stats     !== 'undefined' ? stats     : null
  }) %>
</script>
