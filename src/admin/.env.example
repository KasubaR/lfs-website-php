# ============================================================
# LFS — Lusaka Fitness Squad | Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# Add .env to your .gitignore file.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
SITE_URL=http://localhost:3000

# ── Secrets ──────────────────────────────────────────────────
# Generate strong random strings for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

COOKIE_SECRET=replace-with-a-long-random-string-in-production
JWT_SECRET=replace-with-another-long-random-string-in-production

# ── Database (add when ready) ────────────────────────────────
# DATABASE_URL=mongodb://localhost:27017/lfs
# REDIS_URL=redis://localhost:6379

# ── Email (add when ready) ───────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@lfszambia.run
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="LFS Zambia <noreply@lfszambia.run>"
