<%
/* ============================================================
   LFS SHOP — partials/productCard.ejs
   
   Expected locals:
     product     — Product object from service
     formatPrice — function(number) → 'K X,XXX'
   ============================================================ */

const inStock     = product.sizes?.some(s => s.stock > 0) ?? product.totalStock > 0;
const onSale      = product.comparePrice && product.comparePrice > product.price;
const firstImage  = product.thumbnail || (product.images?.[0]) || '/images/products/placeholder.webp';
const productUrl  = `/shop/product/${product.slug}`;
const sizesInStock = (product.sizes || []).filter(s => s.stock > 0).map(s => s.size);
%>

<article
  class="product-card"
  data-product-id="<%= product._id %>"
  data-product-slug="<%= product.slug %>"
  data-category="<%= product.category %>"
  data-gender="<%= product.gender %>"
  itemscope
  itemtype="https://schema.org/Product"
  aria-label="<%= product.name %>"
>

  <!-- ── Image wrapper ── -->
  <a href="<%= productUrl %>" class="product-card__img-wrap" tabindex="-1" aria-hidden="true">
    <img
      src="<%= firstImage %>"
      alt="<%= product.name %>"
      class="product-card__img"
      loading="lazy"
      width="400"
      height="400"
      itemprop="image"
    >

    <% if (onSale) { %>
      <span class="product-card__badge product-card__badge--sale">
        SALE
      </span>
    <% } %>

    <% if (!inStock) { %>
      <span class="product-card__badge product-card__badge--sold-out">
        Sold Out
      </span>
    <% } %>

    <% if (product.featured) { %>
      <span class="product-card__badge product-card__badge--featured">
        <i class="fas fa-star" aria-hidden="true"></i> Featured
      </span>
    <% } %>

    <!-- Quick view overlay -->
    <button
      class="product-card__quick-view"
      data-product-id="<%= product._id %>"
      data-slug="<%= product.slug %>"
      aria-label="Quick view <%= product.name %>"
      type="button"
    >
      <i class="fas fa-eye" aria-hidden="true"></i>
      Quick View
    </button>
  </a>

  <!-- ── Body ── -->
  <div class="product-card__body">

    <!-- Category label -->
    <span class="product-card__category text-label" aria-label="Category: <%= product.category %>">
      <%= product.category.replace(/-/g, ' ') %>
    </span>

    <!-- Name -->
    <h3 class="product-card__name" itemprop="name">
      <a href="<%= productUrl %>"><%= product.name %></a>
    </h3>

    <!-- Sizes available -->
    <% if (sizesInStock.length > 0) { %>
    <div class="product-card__sizes" aria-label="Available sizes">
      <% sizesInStock.slice(0, 5).forEach(size => { %>
        <span class="product-card__size-chip"><%= size %></span>
      <% }) %>
      <% if (sizesInStock.length > 5) { %>
        <span class="product-card__size-chip product-card__size-chip--more">+<%= sizesInStock.length - 5 %></span>
      <% } %>
    </div>
    <% } %>

    <!-- Price row -->
    <div class="product-card__price-row" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="priceCurrency" content="ZMW">
      <meta itemprop="price" content="<%= product.price %>">
      <meta itemprop="availability" content="<%= inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock' %>">
      <meta itemprop="url" content="<%= productUrl %>">

      <span class="product-card__price product-card__price--current">
        <%= formatPrice(product.price) %>
      </span>

      <% if (onSale) { %>
        <span class="product-card__price product-card__price--compare" aria-label="Was <%= formatPrice(product.comparePrice) %>">
          <%= formatPrice(product.comparePrice) %>
        </span>
      <% } %>

      <!-- Stock status -->
      <% if (!inStock) { %>
        <span class="product-card__stock product-card__stock--out">Out of Stock</span>
      <% } else if (product.totalStock <= 5 && product.totalStock > 0) { %>
        <span class="product-card__stock product-card__stock--low">Only <%= product.totalStock %> left</span>
      <% } %>
    </div>

    <!-- Actions -->
    <div class="product-card__actions">

      <% if (inStock) { %>
        <!-- Size is selected in quick-view or detail page; this triggers quick-view first -->
        <button
          class="btn btn-primary product-card__btn-cart js-quick-add"
          data-product-id="<%= product._id %>"
          data-slug="<%= product.slug %>"
          data-sizes='<%= JSON.stringify(sizesInStock) %>'
          type="button"
          aria-label="Add <%= product.name %> to cart"
        >
          <i class="fas fa-shopping-bag" aria-hidden="true"></i>
          Add to Cart
        </button>
      <% } else { %>
        <button class="btn btn-outline product-card__btn-cart" disabled type="button">
          <i class="fas fa-ban" aria-hidden="true"></i>
          Out of Stock
        </button>
      <% } %>

      <a
        href="<%= productUrl %>"
        class="btn btn-outline product-card__btn-detail"
        aria-label="View details for <%= product.name %>"
      >
        View Details
      </a>

    </div>
  </div><!-- /.product-card__body -->

</article>
