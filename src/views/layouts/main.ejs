<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — LFS' : 'LFS — Lusaka Fitness Squad' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Zambia\'s biggest running community. Train. Run. Compete. Together.' %>">
  <meta name="theme-color" content="#0f0f0f">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/LFS-logo.svg">
  <link rel="alternate icon" href="/images/LFS-logo.svg">

  <!-- Open Graph -->
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' — LFS' : 'LFS — Lusaka Fitness Squad' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Zambia\'s biggest running community.' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.lfszambia.run">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300&display=swap" rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <!-- Tailwind utilities (runtime CDN) -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Design system stylesheets -->
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/cookie-banner.css">

  <!-- Page-specific styles (optional) -->
  <%- typeof styles !== 'undefined' ? styles : '' %>
</head>

<body class="antialiased">

  <!-- ── NAVBAR PARTIAL ── -->
  <%- include('../partials/navbar') %>

  <!-- ── MAIN CONTENT ── -->
  <main id="main-content">
    <%- body %>
  </main>

  <!-- ── FOOTER PARTIAL ── -->
  <%- include('../partials/footer') %>

  <!-- ── FLOATING CART FAB ── -->
  <button class="lfs-cart-fab" onclick="window.location='/shop/cart'" aria-label="View cart (<%= locals.cartCount || 0 %> items)">
    <i class="fas fa-shopping-bag"></i>
    <span class="lfs-cart-fab__count"<%= (locals.cartCount || 0) === 0 ? ' style="display:none"' : '' %>><%= locals.cartCount || 0 %></span>
  </button>


  <!-- Cookie consent banner (server-rendered when no consent) -->
  <%- include('../partials/cookie-banner') %>
  <script src="/js/cookie-banner.js"></script>

  <!-- Global JS -->
  <script>window.__LFS_CART_COUNT__ = <%= locals.cartCount || 0 %>;</script>
  <script src="/js/main.js"></script>
  <script src="/js/cart.js"></script>

  <!-- Page-specific scripts (optional) -->
  <%- typeof scripts !== 'undefined' ? scripts : '' %>

</body>
</html>
