<!-- Public Gallery — albums list. Data: albums[] { _id, title, ... }, optional galleryError -->

<section class="pt-20 px-6 md:px-16 pb-20 bg-black text-white">
  <span class="section-label light"><i class="fas fa-camera" aria-hidden="true"></i> Gallery</span>
  <h1 class="font-['Bebas_Neue'] text-5xl md:text-6xl text-white mb-4">Albums</h1>
  <p class="text-white/80 text-base max-w-2xl mb-12">Photos and videos from LFS runs, races and community events.</p>

  <% if (typeof galleryError !== 'undefined' && galleryError) { %>
  <div class="gallery-public-error" role="alert">
    <i class="fas fa-triangle-exclamation" aria-hidden="true"></i>
    <span><%= galleryError %></span>
  </div>
  <% } %>

  <% if (typeof albums !== 'undefined' && albums.length > 0) { %>
    <div class="gallery-albums-public">
      <% albums.forEach(function(album) { 
           const hasExternal = album.externalUrl && album.externalUrl.trim().length > 0;
           const href = hasExternal ? album.externalUrl : ('/gallery/' + album._id);
        %>
        <a href="<%= href %>" class="gallery-album-card" <%= hasExternal ? 'target="_blank" rel="noopener"' : '' %>>
          <div class="gallery-album-card__cover">
            <% if (album.coverImage) { %>
              <img src="<%= album.coverImage %>" alt="<%= album.title %>" loading="lazy" />
            <% } else { %>
              <div class="gallery-album-card__placeholder">
                <i class="fas fa-images" aria-hidden="true"></i>
              </div>
            <% } %>
          </div>
          <div class="gallery-album-card__body">
            <h2 class="gallery-album-card__title"><%= album.title %></h2>
            <% if (album.category) { %>
              <span class="gallery-album-card__category"><%= album.category %></span>
            <% } %>
            <% if (album.mediaCount != null && album.mediaCount > 0) { %>
              <p class="gallery-album-card__count"><%= album.mediaCount %> item<%= album.mediaCount !== 1 ? 's' : '' %></p>
            <% } %>
          </div>
        </a>
      <% }); %>
    </div>
  <% } else if (locals.fallbackMedia && locals.fallbackMedia.length) { %>
    <p class="text-white/60 mb-8">Albums coming soon — here's a sneak peek from our latest run.</p>
    <div class="gallery-grid" role="list" aria-label="LFS photo gallery">
      <% locals.fallbackMedia.forEach(function(photo, i) { %>
        <%
          var sizeClass = '';
          if (i === 0) sizeClass = 'gallery-grid__item--tall';
          else if (i === 1) sizeClass = 'gallery-grid__item--wide';
        %>
        <div class="gallery-grid__item <%= sizeClass %>" role="listitem">
          <img src="<%= photo.src %>" alt="<%= photo.alt %>" loading="lazy">
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <p class="text-white/70">No albums yet. Check back soon for photos from our runs and events.</p>
  <% } %>
</section>
