<!-- LFS CONTACT US PAGE — pages/contact-us.ejs -->

<!-- ══════════════════════════════════════════════
     1. HERO
     ══════════════════════════════════════════════ -->
<section class="py-20 px-6 md:px-16 bg-black text-white">
  <div class="max-w-4xl" data-reveal>
    <span class="section-label light"><i class="fas fa-envelope" aria-hidden="true"></i> Get In Touch</span>
    <h1 class="font-['Bebas_Neue'] text-5xl md:text-7xl leading-tight mt-4">Contact Us</h1>
    <p class="mt-6 text-white/70 text-lg max-w-2xl">
      Reach out to us or contact the captain of the satellite closest to you.
      We'd love to welcome you into the LFS family.
    </p>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     2. FAQ
     ══════════════════════════════════════════════ -->
<section id="faq" class="py-20 px-6 md:px-16 bg-lfs-off-white">
  <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-start max-w-6xl">
    <!-- Left: FAQ content -->
    <div>
      <span class="section-label" data-reveal><i class="fas fa-circle-question" aria-hidden="true"></i> Help</span>
      <h2 class="font-['Bebas_Neue'] text-5xl md:text-6xl mt-2" data-reveal>FAQ</h2>
      <p class="mt-4 mb-10" style="color:var(--green)" data-reveal>
        Frequently asked questions about LFS — membership, runs, events, and more.
      </p>

      <div class="space-y-3" role="list">
      <details class="faq-item group" data-reveal>
        <summary class="faq-item__question">
          What is LFS?
          <i class="fas fa-chevron-down faq-item__icon" aria-hidden="true"></i>
        </summary>
        <div class="faq-item__answer">
          LFS (Lusaka Fitness Squad) is Zambia's biggest running community. We're a vibrant squad of runners across six satellites in Lusaka, training, running, and competing together since 2017.
        </div>
      </details>

      <details class="faq-item group" data-reveal>
        <summary class="faq-item__question">
          How do I join LFS?
          <i class="fas fa-chevron-down faq-item__icon" aria-hidden="true"></i>
        </summary>
        <div class="faq-item__answer">
          Contact the captain of your nearest satellite (see below) or use the form below. Annual membership is K1,000 — you'll get access to WhatsApp groups, voting rights, and priority event registration.
        </div>
      </details>

      <details class="faq-item group" data-reveal>
        <summary class="faq-item__question">
          When and where do runs happen?
          <i class="fas fa-chevron-down faq-item__icon" aria-hidden="true"></i>
        </summary>
        <div class="faq-item__answer">
          Every Saturday, all six satellites meet for a Long Slow Distance (LSD) run at a rotating host location. Individual satellites also run weekly sessions. See our Satellites section below to find your nearest one.
        </div>
      </details>

      <details class="faq-item group" data-reveal>
        <summary class="faq-item__question">
          Do I need to be a seasoned runner?
          <i class="fas fa-chevron-down faq-item__icon" aria-hidden="true"></i>
        </summary>
        <div class="faq-item__answer">
          No! LFS welcomes all paces and fitness levels. Whether you're just starting or training for a marathon, there's a place for you. Our runs are inclusive and low-pressure.
        </div>
      </details>

      <details class="faq-item group" data-reveal>
        <summary class="faq-item__question">
          What events does LFS organise?
          <i class="fas fa-chevron-down faq-item__icon" aria-hidden="true"></i>
        </summary>
        <div class="faq-item__answer">
          LFS manages Zambia's biggest running events — road races, cross-country, and social runs. We've been delivering world-class race experiences for over 7 years. See our <a href="/#events">Events</a> section for upcoming races.
        </div>
      </details>

      <details class="faq-item group" data-reveal>
        <summary class="faq-item__question">
          How can I get in touch?
          <i class="fas fa-chevron-down faq-item__icon" aria-hidden="true"></i>
        </summary>
        <div class="faq-item__answer">
          Use the form below, email info@lfszambia.run, or call the President at +260 966 755 326. You can also reach your nearest satellite captain directly (see below).
        </div>
      </details>
      </div>
    </div>

    <!-- Right: Contact image -->
    <div class="relative order-first md:order-none contact-page-image-wrap" data-reveal="right">
      <div class="aspect-[4/5] md:aspect-square rounded-lg overflow-hidden shadow-xl contact-page-image">
        <img
          src="/images/contact.jpg"
          alt="LFS runners together at a group run"
          class="w-full h-full object-cover"
          loading="lazy">
      </div>
      <div class="absolute -bottom-4 -left-4 w-20 h-20 rounded-lg flex items-center justify-center z-10"
        style="background:var(--green);color:white" aria-hidden="true">
        <i class="fas fa-users text-2xl" aria-hidden="true"></i>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════
     3. CONTACT INFO + FORM
     ══════════════════════════════════════════════ -->
<section id="contact" class="py-20 px-6 md:px-16 grid md:grid-cols-2 gap-12 bg-black text-white">

  <!-- Contact info -->
  <div data-reveal="left">
    <span class="section-label light"><i class="fas fa-envelope" aria-hidden="true"></i> Reach Us</span>
    <h2 class="font-['Bebas_Neue'] text-5xl md:text-6xl mt-2 text-white">Ready to<br>Join the Squad?</h2>
    <p class="mt-4 text-white/70">
      Whether you have questions about membership, events, or your nearest satellite —
      we're here to help.
    </p>

    <div class="mt-8 space-y-5">
      <div class="contact-row">
        <div class="contact-row__icon"><i class="fas fa-envelope" aria-hidden="true"></i></div>
        <div>
          <div class="contact-row__label">Email</div>
          <div class="contact-row__value"><a href="mailto:info@lfszambia.run">info@lfszambia.run</a></div>
        </div>
      </div>
      <div class="contact-row">
        <div class="contact-row__icon"><i class="fas fa-globe" aria-hidden="true"></i></div>
        <div>
          <div class="contact-row__label">Website</div>
          <div class="contact-row__value">
            <a href="https://www.lfszambia.run" target="_blank" rel="noopener">www.lfszambia.run</a>
          </div>
        </div>
      </div>
      <div class="contact-row">
        <div class="contact-row__icon"><i class="fas fa-map-pin" aria-hidden="true"></i></div>
        <div>
          <div class="contact-row__label">Address</div>
          <div class="contact-row__value">CV-6 COMESA Village, Lusaka Showgrounds, Lusaka, Zambia</div>
        </div>
      </div>
      <div class="contact-row">
        <div class="contact-row__icon" style="color:var(--flag-red);background:rgba(192,57,43,0.1)">
          <i class="fas fa-phone-alt" aria-hidden="true"></i>
        </div>
        <div>
          <div class="contact-row__label">President — Katai Chola</div>
          <div class="contact-row__value">
            <a href="tel:+260966755326">+260 966 755 326</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact form -->
  <div class="p-8 rounded-lg border lfs-form lfs-form--dark" style="background:var(--black-soft);border-color:rgba(255,255,255,0.1)" data-reveal="right" data-native-submit>
    <% if (typeof submitted !== 'undefined' && submitted) { %>
    <div class="mb-6 p-4 rounded-lg lfs-form__success" style="background:rgba(74,124,89,0.2);border:1px solid var(--green);color:var(--green-bright)">
      <i class="fas fa-check-circle mr-2" aria-hidden="true"></i> Your message has been sent. We'll be in touch soon!
    </div>
    <% } %>
    <div class="font-['Bebas_Neue'] text-3xl mb-6 text-white">Send Us a Message</div>
    <form action="/contact" method="post" class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div class="form-group">
          <label for="firstName">First Name</label>
          <input id="firstName" type="text" name="firstName" placeholder="e.g. Katai" autocomplete="given-name" required>
        </div>
        <div class="form-group">
          <label for="lastName">Last Name</label>
          <input id="lastName" type="text" name="lastName" placeholder="e.g. Chola" autocomplete="family-name" required>
        </div>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input id="email" type="email" name="email" placeholder="you@example.com" autocomplete="email" required>
      </div>
      <div class="form-group">
        <label for="phone">Phone</label>
        <input id="phone" type="tel" name="phone" placeholder="+260 9XX XXX XXX" autocomplete="tel">
      </div>
      <div class="form-group">
        <label for="satellite">Nearest Satellite</label>
        <select id="satellite" name="satellite">
          <option value="">Select satellite…</option>
          <option value="arcades">Arcades</option>
          <option value="avondale">Avondale</option>
          <option value="chamba-valley">Chamba Valley</option>
          <option value="woodies">Woodies</option>
          <option value="north-side">North Side</option>
          <option value="south-side">South Side</option>
        </select>
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="4" placeholder="Tell us about yourself…" required></textarea>
      </div>
      <button class="btn btn-primary w-full justify-center mt-2 btn-submit" type="submit"
        aria-label="Send your message to LFS">
        <i class="fas fa-paper-plane mr-2" aria-hidden="true"></i> Send Message
      </button>
    </form>
  </div>

</section>


<!-- ══════════════════════════════════════════════
     4. SATELLITES
     ══════════════════════════════════════════════ -->
<%- include('../partials/satellites', { sectionClass: 'bg-lfs-off-white' }) %>
