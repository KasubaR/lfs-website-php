{
  "name": "lfs-zambia",
  "version": "1.0.0",
  "description": "Lusaka Fitness Squad — official website. Zambia's biggest running community.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:debug": "DEBUG=express:* nodemon src/server.js",
    "build:css": "tailwindcss -i tailwind-input.css -o css/tailwind-build.css --minify",
    "lint": "eslint . --ext .js",
    "test": "echo \"No tests configured yet\" && exit 0"
  },
  "keywords": [
    "lfs",
    "lusaka",
    "fitness",
    "running",
    "zambia"
  ],
  "author": "Lusaka Fitness Squad",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.0"
  },
  "nodemonConfig": {
    "watch": [
      "src/"
    ],
    "ext": "js,ejs,css,json",
    "ignore": [
      "node_modules/",
      "*.log"
    ]
  }
}
